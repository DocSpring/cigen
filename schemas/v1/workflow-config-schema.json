{
  "$id": "https://cigen.dev/schemas/v1/workflow-config-schema.json",
  "title": "CIGen Workflow Configuration Schema",
  "description": "Schema for workflow-level configuration files",
  "type": "object",
  "properties": {
    "dynamic": {
      "type": "boolean",
      "description": "Whether this workflow uses dynamic job skipping based on file changes",
      "default": false
    },
    "output_path": {
      "type": "string",
      "description": "Path where generated CI config will be written",
      "default": "./build"
    },
    "output_filename": {
      "type": "string",
      "description": "Filename for the generated CI config (useful when splitting workflows)",
      "pattern": "^[^/\\\\]+\\.yml$"
    },
    "setup": {
      "type": "boolean",
      "description": "Whether this is a setup workflow that provides CIRCLE_CONTINUATION_KEY",
      "default": false
    },
    "checkout": {
      "description": "Configure initial git checkout behavior (set to false to skip)",
      "oneOf": [
        { "type": "boolean" },
        {
          "type": "object",
          "properties": {
            "shallow": { "type": "boolean", "default": true },
            "clone_options": { "type": "string" },
            "fetch_options": { "type": "string" },
            "tag_fetch_options": { "type": "string" },
            "keyscan": {
              "type": "object",
              "properties": {
                "github": { "type": "boolean" },
                "gitlab": { "type": "boolean" },
                "bitbucket": { "type": "boolean" }
              },
              "additionalProperties": false
            },
            "path": { "type": "string" }
          },
          "additionalProperties": false
        }
      ]
    },
    "run_when": {
      "type": "array",
      "description": "Conditions that must be satisfied for this workflow to run",
      "items": {
        "$ref": "./definitions.json#/definitions/workflowCondition"
      }
    },
    "stages": {
      "type": "array",
      "description": "Ordered workflow stages and their dependencies",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "needs": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        },
        "required": ["name"],
        "additionalProperties": false
      },
      "default": []
    },
    "stage_prefix": {
      "type": "boolean",
      "description": "Prefix job names with their stage name",
      "default": false
    },
    "default_stage_prefix": {
      "type": "boolean",
      "description": "Prefix jobs in the default stage as well",
      "default": false
    },
    "stage_prefix_separator": {
      "type": "string",
      "description": "Separator between stage name and job name when stage_prefix is enabled",
      "default": "_"
    }
  },
  "additionalProperties": false
}
